{
  "tests": [
    {
      "name": "Без авторизации возвращает 401",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 401
    },
    {
      "name": "Список обращений пользователя",
      "method": "GET",
      "path": "/?action=list",
      "headers": {"X-User-Id": "1"},
      "expectedStatus": 200,
      "expectedBody": {"tickets": "array"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Создание обращения без темы возвращает 400",
      "method": "POST",
      "path": "/?action=create",
      "headers": {"X-User-Id": "1"},
      "body": {"request_type": "question", "priority": "normal", "subject": "", "message": "test"},
      "expectedStatus": 400
    },
    {
      "name": "Создание обращения",
      "method": "POST",
      "path": "/?action=create",
      "headers": {"X-User-Id": "1"},
      "body": {"request_type": "question", "priority": "normal", "subject": "Тестовое обращение", "message": "Текст вопроса", "user_name": "Тест"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}
