{
  "tests": [
    {
      "name": "OPTIONS request",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing user_id",
      "method": "GET",
      "path": "/?action=folders",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "List folders for user",
      "method": "GET",
      "path": "/?action=folders&user_id=1",
      "expectedStatus": 200,
      "expectedBody": {"folders": "array"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing folder_id for photos",
      "method": "GET",
      "path": "/?action=photos&user_id=1",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "List photos in folder",
      "method": "GET",
      "path": "/?action=photos&user_id=1&folder_id=1",
      "expectedStatus": 200,
      "expectedBody": {"photos": "array"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Delete folder missing folder_id",
      "method": "POST",
      "path": "/",
      "body": {"action": "delete_folder", "user_id": "1"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Delete photos missing photo_ids",
      "method": "POST",
      "path": "/",
      "body": {"action": "delete_photos", "user_id": "1"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "S3 presign missing key",
      "method": "GET",
      "path": "/?action=s3_presign&user_id=1",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "S3 upload missing files",
      "method": "POST",
      "path": "/",
      "body": {"action": "s3_upload", "user_id": "1"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "S3 delete folder missing prefix",
      "method": "POST",
      "path": "/",
      "body": {"action": "s3_delete_folder", "user_id": "1", "prefix": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}