{
  "tests": [
    {
      "name": "Register without portfolio rejected",
      "method": "POST",
      "body": {
        "action": "register",
        "email": "test@example.com",
        "password": "securepass123",
        "phone": "+79991234567"
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Complete OAuth profile without user_id rejected",
      "method": "POST",
      "body": {
        "action": "complete-oauth-profile",
        "email": "photographer@example.com",
        "phone": "+79991234567",
        "portfolio_links": ["https://example.com/portfolio"]
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    }
  ]
}